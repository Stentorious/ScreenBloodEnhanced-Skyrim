						"min": 0,
						"max": 180,
						"step": 1,
						"sourceType": "ModSettingFloat",
						"formatString": "{0}°"
					}
				},
				{
					"type": "empty"
				},
				{
					"text": "$Strength",
					"type": "header"
				},
				{
					"id": "iCount:BloodSplatter",
