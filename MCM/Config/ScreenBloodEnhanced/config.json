{
	"$schema": "https://raw.githubusercontent.com/Exit-9B/MCM-Helper/main/docs/config.schema.json",
	"modName": "ScreenBloodEnhanced",
	"displayName": "$ScreenBloodEnhanced",
	"minMcmVersion": 13,
	"customContent": {
		"source": "ScreenBloodEnhanced/Splash.dds",
		"x": 120,
		"y": 95
	},
	"pages": [
		{
			"pageDisplayName": "$General",
			"cursorFillMode": "topToBottom",
			"content": [
				{
					"text": "$Main",
					"type": "header"
				},
				{
					"id": "iEffectReceive:General",
					"text": "$DamageTaken",
					"type": "enum",
					"help": "$DamageTakenHelp",
					"valueOptions": {
						"options": ["$Disabled", "$Vanilla"],
						"sourceType": "ModSettingInt"
					}
				},
				{
					"id": "iEffectDeal:General",
					"text": "$DamageDealt",
					"type": "enum",
					"help": "$DamageDealtHelp",
					"valueOptions": {
						"options": ["$Disabled", "$Enhanced"],
						"sourceType": "ModSettingInt"
					}
				},
				{
					"type": "empty"
				},
				{
					"text": "$Controls",
					"type": "header"
				},
				{
					"id": "iKeybind:Controls",
					"type": "keymap",
					"text": "$Keybind",
					"help": "$KeybindHelp",
					"ignoreConflicts": false,
					"valueOptions": {
						"sourceType": "ModSettingInt"
					}
				},
				{
					"type": "empty"
				},
				{
					"text": "$Animation",
					"type": "header"
				},
				{
					"id": "iVariantDefault:Animation",
					"text": "$VariantDefault",
					"type": "enum",
					"help": "$VariantDefaultHelp",
					"valueOptions": {
						"options": ["$Default", "$AltFaster"],
						"sourceType": "ModSettingInt"
					}
				},
				{
					"id": "iVariantCombat:Animation",
					"text": "$VariantCombat",
					"type": "enum",
					"help": "$VariantCombatHelp",
					"valueOptions": {
						"options": ["$Default", "$AltFaster"],
						"sourceType": "ModSettingInt"
					}
				},
				{
					"id": "bLeftArmOnly:Animation",
					"type": "toggle",
					"text": "$LeftArmOnly",
					"help": "$LeftArmOnlyHelp",
					"valueOptions": {
						"sourceType": "ModSettingBool"
					}
				}
			]

		},
		{
			"pageDisplayName": "$Effect",
			"cursorFillMode": "topToBottom",
			"content": [
				{
					"text": "$Visibility",
					"type": "header"
				},
				{
					"id": "fDistance:Visibility",
