					"type": "slider",
					"help": "$DistanceHelp",
					"valueOptions": {
						"min": 0,
						"max": 10,
						"step": 0.1,
						"sourceType": "ModSettingFloat",
						"formatString": "{1}m"
					}
				},
				{
					"id": "fHeadingAngle:Visibility",
					"text": "$HeadingAngle",
					"type": "slider",
					"help": "$HeadingAngleHelp",
